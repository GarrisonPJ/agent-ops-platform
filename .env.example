# ── Database ──────────────────────────────────────────
POSTGRES_USER=agentops
POSTGRES_PASSWORD=agentops
POSTGRES_DB=agentops

# ── API ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*
DATABASE_URL=postgresql+asyncpg://agentops:agentops@db:5432/agentops
DEBUG=false

# ── LLM Providers ─────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=4096
LLM_MAX_STEPS=15

# ── Executor ──────────────────────────────────────────
EXECUTOR_MODE=docker

# ── Context Window ────────────────────────────────────
CONTEXT_WINDOW_LIMIT=128000
