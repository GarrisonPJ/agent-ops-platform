# Phase 1 local demo configuration
POSTGRES_USER=agentops
POSTGRES_PASSWORD=agentops
POSTGRES_DB=agentops

API_PORT=8000
WEB_PORT=5173

# The local full stack uses the real API. Static hosting sets this to true to
# replay recorded Golden E2E fixtures without reimplementing backend logic.
VITE_MOCK_API=false

# Shared only by the local FastAPI control plane and Rust runner.
# Replace this value before using the stack outside local development.
RUNNER_TOKEN=local-runner-token
