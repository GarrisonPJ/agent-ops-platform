{
  "$defs": {
    "EvaluationLimits": {
      "additionalProperties": false,
      "properties": {
        "max_output_bytes": {
          "default": 1048576,
          "maximum": 10485760,
          "minimum": 1024,
          "title": "Max Output Bytes",
          "type": "integer"
        },
        "timeout_ms": {
          "default": 60000,
          "maximum": 300000,
          "minimum": 1000,
          "title": "Timeout Ms",
          "type": "integer"
        }
      },
      "title": "EvaluationLimits",
      "type": "object"
    },
    "PolicyPatch": {
      "additionalProperties": false,
      "properties": {
        "instruction_patch": {
          "items": {
            "maxLength": 500,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 10,
          "title": "Instruction Patch",
          "type": "array"
        },
        "max_steps": {
          "maximum": 20,
          "minimum": 3,
          "title": "Max Steps",
          "type": "integer"
        },
        "tool_priority": {
          "additionalProperties": {
            "maximum": 1.0,
            "minimum": 0.0,
            "type": "number"
          },
          "title": "Tool Priority",
          "type": "object"
        }
      },
      "required": [
        "max_steps"
      ],
      "title": "PolicyPatch",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "experiment_id": {
      "title": "Experiment Id",
      "type": "string"
    },
    "limits": {
      "$ref": "#/$defs/EvaluationLimits"
    },
    "policy": {
      "anyOf": [
        {
          "$ref": "#/$defs/PolicyPatch"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "scenario_id": {
      "const": "checkout-api-latency",
      "default": "checkout-api-latency",
      "title": "Scenario Id",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "seed": {
      "default": 42,
      "maximum": 2147483647,
      "minimum": 0,
      "title": "Seed",
      "type": "integer"
    },
    "task": {
      "maxLength": 4000,
      "minLength": 1,
      "title": "Task",
      "type": "string"
    }
  },
  "required": [
    "run_id",
    "experiment_id",
    "task"
  ],
  "title": "EvaluationSpec",
  "type": "object"
}
